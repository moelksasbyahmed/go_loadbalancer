    "version": "0.2.0",
    "configurations": [

        {
            "name": "Launch Go LoadBalancer",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/CLI",
            "env": {},
            "args": ["start", "-c","${workspaceFolder}/config.yaml", "-p", "5000"]
        },
        {
            "name" : "Testing Abort Server",
            "type": "go",
            "request" : "launch",
            "mode" : "auto",
            "program" : "${workspaceFolder}/cmd/CLI",
            "env" : {},
            "args" : ["abort"]
        },
        {
            "name" : "Testing Add Server",
            "type": "go",
            "request" : "launch",
            "mode" : "auto",
            "program" : "${workspaceFolder}/cmd/CLI",
            "env" : {},
            "args" : ["add", "-n", "backend1", "-u", "http://localhost:5001", "-m", "10"]
        }

    ]
}